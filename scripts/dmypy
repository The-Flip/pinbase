#!/usr/bin/env bash
# Daemon variant of scripts/mypy — runs `dmypy check` against a pre-warmed
# daemon for faster repeat runs. Used by the pre-commit hook and the VS Code
# mypy extension. If the daemon gets out of sync: `make mypy-restart`.
set -eu

# `dmypy run` auto-starts the daemon but has a hardcoded client-side connect
# timeout (~30s) that can fire on slow hosts / cold CI runners. `dmypy start`
# blocks until the daemon is listening, so we use start+check instead. On warm
# sessions the status check short-circuits.
if ! uv run --directory backend dmypy status >/dev/null 2>&1; then
    uv run --directory backend dmypy start -- --config-file pyproject.toml
fi

# `dmypy check` uses the config baked into the running daemon at start time, so
# config flags go on `dmypy start` (above) — passing them here would be treated
# as positional FILE arguments. Always run the full backend tree (callers may
# pass paths; ignore them for output consistency).
uv run --directory backend dmypy check -- .
